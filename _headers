# Cloudflare Pages — cache policy
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# Stylesheets are content-hashed (s<md5>.css), so the filename changes whenever
# the CSS changes. That makes them safe to cache forever.
/css/*
  Cache-Control: public, max-age=31536000, immutable

# Images and icons are NOT content-hashed, so keep the cache long but not
# immutable — a re-deploy should still be able to replace them within 30 days.
/*.webp
  Cache-Control: public, max-age=2592000
/*.png
  Cache-Control: public, max-age=2592000
/*.svg
  Cache-Control: public, max-age=2592000
/*.jpg
  Cache-Control: public, max-age=2592000
/*.ico
  Cache-Control: public, max-age=2592000

# navigation.js is not hashed and now only carries interactivity — keep it
# short so fixes ship quickly.
/navigation.js
  Cache-Control: public, max-age=3600, must-revalidate

# HTML must always revalidate, or students see stale calculators after a deploy.
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Discovery + verification files must never be served stale.
/sitemap.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
/ads.txt
  Cache-Control: public, max-age=3600
/llms.txt
  Cache-Control: public, max-age=3600

# Low-risk security headers. Deliberately no X-Frame-Options / CSP here, so
# nothing can interfere with the AdSense review or ad serving.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
